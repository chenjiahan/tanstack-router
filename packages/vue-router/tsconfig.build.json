{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "moduleResolution": "Bundler",
    "rootDir": "src",
    "isolatedDeclarations": true,
    "allowJs": false,
    "checkJs": false,
    "outDir": "dist/source",
    "noEmit": false,
    "declaration": true,
    "sourceMap": true
  },
  "include": ["src"]
}
