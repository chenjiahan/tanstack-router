{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "moduleResolution": "Bundler",
    "rootDir": "src",
    "isolatedDeclarations": true,
    "allowJs": false,
    "checkJs": false,
    "outDir": "dist/source",
    "noEmit": false,
    "declaration": true,
    "sourceMap": true,
    "paths": {
      "@tanstack/router-devtools-core": ["../../router-devtools-core/src"]
    }
  },
  "include": ["src"]
}
